{
  "permissions": {
    "allow": [
      "PowerShell(Start-Sleep -Seconds 6; Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing -TimeoutSec 5 2>&1 | Select-Object -ExpandProperty StatusCode)",
      "PowerShell(Start-Sleep -Seconds 5; \\(Invoke-WebRequest \"http://localhost:3000/login\" -UseBasicParsing\\).StatusCode)",
      "PowerShell(Stop-Process *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "PowerShell(head *)",
      "PowerShell(npx playwright --version 2>&1)",
      "PowerShell($response = Invoke-WebRequest -Uri \"http://localhost:3000/dashboard\" -MaximumRedirection 0 -ErrorAction SilentlyContinue; \"Status: $\\($response.StatusCode\\)\"; \"Location: $\\($response.Headers.Location\\)\")",
      "PowerShell(curl.exe -s -o NUL -w \"HTTP %{http_code} -> Location: %{redirect_url}\" --max-redirs 0 \"http://localhost:3000/dashboard\")",
      "PowerShell(curl.exe -s -o NUL -w \"HTTP %{http_code}\" \"http://localhost:3000/login\")",
      "PowerShell(dashboard *)",
      "Read(//mnt/c/Projects/**)",
      "Bash(npm run *)",
      "PowerShell(git init *)"
    ]
  }
}
